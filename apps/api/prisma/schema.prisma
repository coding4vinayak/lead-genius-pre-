generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  active
  unsubscribed
  bounced
  invalid
}

enum Channel {
  email
  whatsapp
}

enum Direction {
  outbound
  inbound
}

enum MessageStatus {
  queued
  sent
  delivered
  failed
  bounced
  replied
}

enum CampaignStatus {
  draft
  scheduled
  running
  paused
  completed
}

enum ScheduleType {
  immediate
  scheduled
  recurring
}

enum SendStrategy {
  sequential
  batch
  burst
}

enum AiProvider {
  openai
  gemini
  anthropic
}

enum IntentCategory {
  interested
  not_interested
  out_of_office
  meeting_request
  pricing_question
  feature_question
  competitor_mention
  spam
  other
}

enum LeadStage {
  new
  contacted
  engaged
  warm
  hot
  converted
  lost
}

enum SequenceStatus {
  draft
  active
  paused
  completed
}

enum SequenceStepType {
  send_email
  send_whatsapp
  delay
  condition
  update_lead_stage
  update_lead_score
}

enum SequenceEnrollmentStatus {
  active
  paused
  completed
  exited
}

enum SequenceStepExecutionStatus {
  pending
  completed
  failed
  skipped
}

model Lead {
  id              String     @id @default(cuid())
  email           String?
  phone           String?
  name            String?
  company         String?
  title           String?
  source          String?
  status          LeadStatus @default(active)
  tags            String[]
  customFields    Json?
  score           Int?
  stage           LeadStage  @default(new)
  enrichmentData  Json?
  intentAnalysis  Json?
  currentStep     String?
  nextActionAt    DateTime?
  lastContactedAt DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  groupMembers        GroupMember[]
  messages            Message[]
  sequenceEnrollments SequenceEnrollment[]

  @@index([status])
  @@index([email])
  @@index([tags])
  @@index([score])
  @@index([stage])
}

model LeadGroup {
  id          String       @id @default(cuid())
  name        String
  description String?
  filterRules Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  members GroupMember[]

  @@index([name])
}

model GroupMember {
  leadId     String
  groupId    String
  assignedAt DateTime @default(now())

  lead  Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  group LeadGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([leadId, groupId])
}

model Template {
  id        String   @id @default(cuid())
  name      String
  channel   Channel
  subject   String?
  body      String
  variables String[]
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaigns Campaign[]

  @@index([channel])
  @@index([category])
}

model Campaign {
  id            String         @id @default(cuid())
  name          String
  description   String?
  status        CampaignStatus @default(draft)
  channel       Channel
  templateId    String
  leadGroupIds  String[]
  productFilter String?
  scheduleType  ScheduleType   @default(immediate)
  scheduledAt   DateTime?
  recurringRule String?
  sendStrategy  SendStrategy   @default(sequential)
  dailyLimit    Int?
  minDelayMs    Int?
  sentCount     Int            @default(0)
  failedCount   Int            @default(0)
  replyCount    Int            @default(0)
  openedCount   Int            @default(0)
  clickedCount  Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  template Template @relation(fields: [templateId], references: [id])
  messages Message[]

  @@index([status])
  @@index([createdAt])
}

model Message {
  id              String        @id @default(cuid())
  campaignId      String?
  leadId          String
  channel         Channel
  direction       Direction     @default(outbound)
  subject         String?
  body            String
  status          MessageStatus @default(queued)
  providerId      String?
  errorMessage    String?
  isAiGenerated   Boolean       @default(false)
  intentAnalysis  Json?
  draftReply      String?
  reviewStatus    String?
  deliveredAt     DateTime?
  readAt          DateTime?
  createdAt       DateTime      @default(now())

  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  lead     Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([leadId])
  @@index([status])
  @@index([createdAt])
  @@index([reviewStatus])
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  password        String
  role            String    @default("user")
  resetToken      String?
  resetTokenExpires DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tasks Task[]

  @@index([email])
  @@index([resetToken])
}

model Settings {
  id                 String @id @default("global")
  smtpHost           String?
  smtpPort           Int?
  smtpUser           String?
  smtpPass           String?
  sendgridApiKey     String?
  twilioAccountSid   String?
  twilioAuthToken    String?
  twilioFromNumber   String?
  fromEmail          String?
  fromName           String?
  dailyGlobalLimit   Int?
  defaultMinDelayMs  Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AgentSettings {
  id                 String     @id @default("global")
  aiProvider         AiProvider @default(openai)
  aiModel            String     @default("gpt-4o-mini")
  aiApiKey           String?
  aiBaseUrl          String?
  tone               String     @default("professional")
  autoReplyThreshold Int        @default(70)
  isAutoPilotActive  Boolean    @default(false)
  maxDailyReplies    Int        @default(50)
  workingHoursStart  String?
  workingHoursEnd    String?
  humanHandoffRules  Json?
  autoReplyEnabled   Boolean    @default(false)
  reviewQueueEnabled Boolean    @default(true)
  excludedIntents    String[]
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

enum AutomationStatus {
  active
  inactive
  draft
}

enum AutomationTriggerType {
  lead_created        @map("lead.created")
  lead_updated        @map("lead.updated")
  lead_field_changed  @map("lead.field_changed")
  lead_tag_added      @map("lead.tag_added")
  lead_tag_removed    @map("lead.tag_removed")
  lead_score_threshold @map("lead.score_threshold")
  message_received    @map("message.received")
  message_sent        @map("message.sent")
  message_bounced     @map("message.bounced")
  campaign_activated  @map("campaign.activated")
  campaign_paused     @map("campaign.paused")
  campaign_completed  @map("campaign.completed")
  webhook_received    @map("webhook.received")
  cron
  manual
}

enum AutomationStepType {
  send_message
  update_lead_field
  add_tag
  remove_tag
  move_to_group
  remove_from_group
  pause_campaign
  send_webhook
  delay
  condition
  create_task
}

enum AutomationExecutionStatus {
  running
  completed
  failed
  cancelled
}

enum WebhookDeliveryStatus {
  pending
  delivered
  failed
}

enum IntegrationType {
  slack
  hubspot
  salesforce
  zapier
  n8n
  custom
}

enum TaskStatus {
  pending
  in_progress
  completed
  cancelled
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

model Automation {
  id            String               @id @default(cuid())
  name          String
  description   String?
  triggerType   AutomationTriggerType
  triggerConfig Json                 @default("{}")
  status        AutomationStatus     @default(draft)
  isActive      Boolean              @default(false)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  steps           AutomationStep[]
  executions      AutomationExecution[]
  inboundWebhooks InboundWebhook[]
  tasks           Task[]

  @@index([status])
  @@index([triggerType])
  @@index([isActive])
}

model AutomationStep {
  id                   String             @id @default(cuid())
  automationId         String
  type                 AutomationStepType
  config               Json               @default("{}")
  position             Int
  nextStepId           String?
  conditionTrueStepId  String?
  conditionFalseStepId String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  automation     Automation               @relation(fields: [automationId], references: [id], onDelete: Cascade)
  executionSteps AutomationExecutionStep[]

  @@index([automationId])
  @@index([position])
}

model AutomationExecution {
  id             String                    @id @default(cuid())
  automationId   String
  triggerEvent   String
  triggerPayload Json?
  status         AutomationExecutionStatus @default(running)
  startedAt      DateTime                  @default(now())
  completedAt    DateTime?
  errorMessage   String?

  automation Automation                @relation(fields: [automationId], references: [id], onDelete: Cascade)
  steps      AutomationExecutionStep[]

  @@index([automationId])
  @@index([status])
  @@index([startedAt])
}

model AutomationExecutionStep {
  id           String                    @id @default(cuid())
  executionId  String
  stepId       String
  status       AutomationExecutionStatus @default(running)
  input        Json?
  output       Json?
  startedAt    DateTime                  @default(now())
  completedAt  DateTime?
  errorMessage String?

  execution AutomationExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  step      AutomationStep      @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@index([stepId])
}

model Event {
  id         String   @id @default(cuid())
  type       String
  entityType String
  entityId   String
  payload    Json
  createdAt  DateTime @default(now())

  @@index([type])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model WebhookSubscription {
  id        String   @id @default(cuid())
  name      String
  url       String
  events    String[]
  secret    String?
  headers   Json?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveries WebhookDelivery[]

  @@index([isActive])
}

model WebhookDelivery {
  id             String               @id @default(cuid())
  webhookId      String
  event          String
  payload        Json
  responseStatus Int?
  responseBody   String?
  attempts       Int                  @default(0)
  maxAttempts    Int                  @default(5)
  nextRetryAt    DateTime?
  lastAttemptAt  DateTime?
  status         WebhookDeliveryStatus @default(pending)
  createdAt      DateTime             @default(now())

  webhook WebhookSubscription @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([status])
  @@index([nextRetryAt])
}

model InboundWebhook {
  id           String   @id @default(cuid())
  name         String
  description  String?
  token        String   @unique
  secret       String?
  automationId String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  automation Automation? @relation(fields: [automationId], references: [id], onDelete: SetNull)

  @@index([token])
  @@index([isActive])
}

model Integration {
  id          String          @id @default(cuid())
  type        IntegrationType
  name        String
  config      Json            @default("{}")
  credentials Json?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([type])
  @@index([isActive])
}

model Task {
  id                    String       @id @default(cuid())
  title                 String
  description           String?
  assigneeId            String?
  status                TaskStatus   @default(pending)
  priority              TaskPriority @default(medium)
  dueDate               DateTime?
  automationId          String?
  automationExecutionId String?
  metadata              Json?
  completedAt           DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  assignee   User?       @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  automation Automation? @relation(fields: [automationId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([priority])
  @@index([assigneeId])
  @@index([automationId])
  @@index([dueDate])
}

model Sequence {
  id                 String         @id @default(cuid())
  name               String
  description        String?
  status             SequenceStatus @default(draft)
  leadGroupIds       String[]
  triggerType        String         @default("manual")
  triggerConfig      Json           @default("{}")
  pauseOnReply       Boolean        @default(true)
  sendingWindowStart String?
  sendingWindowEnd   String?
  dailyLimit         Int?
  timezone           String         @default("UTC")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  steps       SequenceStep[]
  enrollments SequenceEnrollment[]

  @@index([status])
  @@index([createdAt])
}

model SequenceStep {
  id                   String           @id @default(cuid())
  sequenceId           String
  position             Int
  type                 SequenceStepType
  config               Json             @default("{}")
  nextStepId           String?
  conditionTrueStepId  String?
  conditionFalseStepId String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  sequence   Sequence                @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  executions SequenceStepExecution[]

  @@index([sequenceId])
  @@index([position])
}

model SequenceEnrollment {
  id            String                     @id @default(cuid())
  sequenceId    String
  leadId        String
  status        SequenceEnrollmentStatus   @default(active)
  currentStepId String?
  nextRunAt     DateTime?
  startedAt     DateTime                   @default(now())
  completedAt   DateTime?
  exitReason    String?
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  sequence       Sequence                @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  lead           Lead                    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  stepExecutions SequenceStepExecution[]

  @@index([sequenceId])
  @@index([leadId])
  @@index([status])
  @@index([nextRunAt])
}

model SequenceStepExecution {
  id           String                       @id @default(cuid())
  enrollmentId String
  stepId       String
  status       SequenceStepExecutionStatus  @default(pending)
  executedAt   DateTime?
  result       Json?
  createdAt    DateTime                     @default(now())

  enrollment SequenceEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  step       SequenceStep       @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([enrollmentId])
  @@index([stepId])
}

model ChannelHealth {
  id              String   @id @default(cuid())
  channel         Channel
  provider        String
  status          String   @default("healthy")
  dailySent       Int      @default(0)
  dailyBounced    Int      @default(0)
  dailyComplaints Int      @default(0)
  deliveryRate    Float    @default(100)
  bounceRate      Float    @default(0)
  lastCheckedAt   DateTime @default(now())
  lastErrorMessage String?
  quotaUsed       Int      @default(0)
  quotaLimit      Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([channel, provider])
  @@index([channel])
  @@index([status])
}

model WhatsAppTemplate {
  id               String   @id @default(cuid())
  name             String
  language         String   @default("en")
  category         String   @default("marketing")
  status           String   @default("pending")
  body             String
  headerType       String?
  headerContent    String?
  footerText       String?
  buttons          Json?
  twilioTemplateSid String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([category])
}

model EmailDomainAuth {
  id             String    @id @default(cuid())
  domain         String    @unique
  spfStatus      String    @default("pending")
  dkimStatus     String    @default("pending")
  dmarcStatus    String    @default("pending")
  lastVerifiedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([domain])
}
